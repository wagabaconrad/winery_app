# =============================================================
# Winery OS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to version control.
# =============================================================

# ---- Database (Supabase PostgreSQL) -------------------------
# Use the pooler URL (port 5432 via pgBouncer) for production.
# Find it in: Supabase Dashboard → Project → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ---- Clerk Authentication -----------------------------------
# Use pk_live_ / sk_live_ keys for production (NOT pk_test_).
# Find them in: Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Webhook signing secret — from: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ---- Supabase Client SDK ------------------------------------
# Find in: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJ...

# ---- App URL ------------------------------------------------
# Used by /api/auth/reset redirect. Set to your production domain.
NEXT_PUBLIC_APP_URL=https://yourdomain.com
